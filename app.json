{
  "expo": {
    "name": "Night Guard",
    "slug": "night-guard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.laxit.nightguard"
    },
    "android": {
      "package": "com.laxit.nightguard",
      "permissions": ["INTERNET", "VIBRATE"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d03f9f2e-36ee-43a9-b521-a602bf9bdd40"
      }
    },
    "owner": "laxitghgh"
  }
}
